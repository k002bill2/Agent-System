# API Backend URL (required for production)
# Leave empty in development (uses Vite proxy)
VITE_API_URL=

# Example for production:
# VITE_API_URL=https://your-backend-api.com

# PostHog Analytics (Self-hosted)
VITE_POSTHOG_KEY=phc_your_project_api_key_here
VITE_POSTHOG_HOST=http://your-posthog-host:8000
