# Backend Dockerfile (Full Features)
# Includes: ChromaDB, RAG, Docker SDK, all LLM providers

FROM python:3.11-slim

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y \
    build-essential \
    curl \
    git \
    && rm -rf /var/lib/apt/lists/*

# Install uv for fast dependency management
RUN pip install --no-cache-dir uv

# Copy source code first (needed for pyproject.toml readme reference)
COPY . .

# Install all dependencies (including heavy ML models)
# Creates empty README.md if not exists (required by pyproject.toml)
RUN touch README.md && uv pip install --system -e .

# Create data directories
RUN mkdir -p /app/data/chromadb /app/data/summaries

# Non-root user for security
RUN useradd -m -u 1000 aos && \
    mkdir -p /home/aos/.claude/projects && \
    chown -R aos:aos /app /home/aos
USER aos

# Environment
ENV PORT=8000
ENV PYTHONUNBUFFERED=1

EXPOSE $PORT

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=40s --retries=3 \
    CMD curl -f http://localhost:8000/health || exit 1

# Run the application
CMD ["uvicorn", "api.app:app", "--host", "0.0.0.0", "--port", "8000"]
