# Agent Orchestration Service - Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# =============================================================================
# LLM Provider Configuration (choose one)
# =============================================================================

# Provider: google (default), anthropic, or ollama
LLM_PROVIDER=google

# Google Gemini API
GOOGLE_API_KEY=your_google_api_key_here

# Anthropic Claude API (alternative)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API (optional)
# OPENAI_API_KEY=your_openai_api_key_here

# Ollama (local, no API key needed)
# OLLAMA_BASE_URL=http://host.docker.internal:11434

# =============================================================================
# OAuth Authentication (optional - for multi-user setup)
# =============================================================================

# Google OAuth
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret

# GitHub OAuth
# GITHUB_CLIENT_ID=your_github_client_id
# GITHUB_CLIENT_SECRET=your_github_client_secret

# =============================================================================
# Security (change in production!)
# =============================================================================

# JWT Secret Key - CHANGE THIS!
SESSION_SECRET_KEY=aos-secret-key-change-in-production

# Field Encryption (hex-encoded 32-byte key, generate with: python -c "import os; print(os.urandom(32).hex())")
# Leave empty to disable field encryption (plaintext storage)
# ENCRYPTION_MASTER_KEY=

# =============================================================================
# Database (auto-configured by docker-compose)
# =============================================================================

# For local development:
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/agent_orchestrator

# For docker-compose (auto-set):
# DATABASE_URL=postgresql+asyncpg://aos:aos@postgres:5432/aos

REDIS_URL=redis://localhost:6379/0
USE_DATABASE=true

# Database TLS (optional)
# DB_SSL_MODE=require  # require, verify-ca, verify-full
# DB_SSL_CERT_PATH=

# Redis TLS (optional)
# REDIS_SSL=false

# =============================================================================
# Server Configuration
# =============================================================================

HOST=0.0.0.0
PORT=8000
DEBUG=false
LOG_LEVEL=INFO

# Frontend URL (for OAuth callbacks)
FRONTEND_URL=http://localhost:5173

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# =============================================================================
# Claude Code Usage Monitoring (optional)
# =============================================================================

# OAuth token priority: 1) Dashboard Settings 2) env var 3) macOS Keychain
# Local dev: Keychain auto-detected, no config needed
# Deployment (Docker/Linux): set env var or use Dashboard Settings
# CLAUDE_OAUTH_TOKEN=your_oauth_token_here

# =============================================================================
# Orchestration
# =============================================================================

MAX_ITERATIONS=100
DEFAULT_MODEL=claude-opus-4-6

# =============================================================================
# Claude Code Agent Teams (experimental)
# =============================================================================

CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS=1
CLAUDE_CODE_TEAMMATE_MODE=tmux
