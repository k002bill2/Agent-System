# Agent Orchestration Service - Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# =============================================================================
# LLM Provider Configuration (choose one)
# =============================================================================

# Provider: google (default), anthropic, or ollama
LLM_PROVIDER=google

# Google Gemini API
GOOGLE_API_KEY=your_google_api_key_here

# Anthropic Claude API (alternative)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API (optional)
# OPENAI_API_KEY=your_openai_api_key_here

# Ollama (local, no API key needed)
# OLLAMA_BASE_URL=http://host.docker.internal:11434

# =============================================================================
# OAuth Authentication (optional - for multi-user setup)
# =============================================================================

# Google OAuth
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret

# GitHub OAuth
# GITHUB_CLIENT_ID=your_github_client_id
# GITHUB_CLIENT_SECRET=your_github_client_secret

# =============================================================================
# Security (change in production!)
# =============================================================================

# JWT Secret Key - CHANGE THIS!
SESSION_SECRET_KEY=aos-secret-key-change-in-production

# =============================================================================
# Database (auto-configured by docker-compose)
# =============================================================================

# For local development:
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/agent_orchestrator

# For docker-compose (auto-set):
# DATABASE_URL=postgresql+asyncpg://aos:aos@postgres:5432/aos

REDIS_URL=redis://localhost:6379/0
USE_DATABASE=true

# =============================================================================
# Server Configuration
# =============================================================================

HOST=0.0.0.0
PORT=8000
DEBUG=false
LOG_LEVEL=INFO

# Frontend URL (for OAuth callbacks)
FRONTEND_URL=http://localhost:5173

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# =============================================================================
# Claude Code Usage Monitoring (optional)
# =============================================================================

# OAuth token for Anthropic Usage API (required on non-macOS)
# On macOS, auto-extracted from Keychain if not set
# CLAUDE_OAUTH_TOKEN=your_oauth_token_here

# Claude Code stats cache path (default: ~/.claude/stats-cache.json)
# CLAUDE_STATS_CACHE_PATH=/path/to/stats-cache.json

# Usage API cache path (default: ~/.claude/aos-usage-cache.json)
# CLAUDE_USAGE_CACHE_PATH=/path/to/aos-usage-cache.json

# =============================================================================
# Orchestration
# =============================================================================

MAX_ITERATIONS=100
DEFAULT_MODEL=claude-sonnet-4-20250514
