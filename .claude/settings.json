{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -c \"import json,sys; p=json.load(sys.stdin).get('tool_input',{}).get('file_path',''); blocked=['.env','secrets','.git/','/prod/']; sys.exit(2 if any(b in p for b in blocked) else 0)\"",
            "timeout": 5,
            "statusMessage": "Path protection..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/ethicalValidator.js 2>/dev/null || true",
            "timeout": 5,
            "statusMessage": "Safety check..."
          }
        ]
      },
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/parallelCoordinator.js pre 2>/dev/null || true",
            "timeout": 5,
            "statusMessage": "Parallel coordination..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/agentTracer.js 2>/dev/null || true",
            "timeout": 5,
            "statusMessage": "Agent tracing..."
          },
          {
            "type": "command",
            "command": "node .claude/hooks/parallelCoordinator.js post 2>/dev/null || true",
            "timeout": 5,
            "statusMessage": "Parallel cleanup..."
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/autoFormatter.js 2>/dev/null || true",
            "timeout": 10,
            "statusMessage": "Auto formatting..."
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.message' | xargs -I{} osascript -e 'display notification \"{}\" with title \"Claude Code\"'",
            "timeout": 5,
            "statusMessage": "Notifying..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/contextMonitor.js 2>/dev/null || true",
            "timeout": 5,
            "statusMessage": "Context monitoring..."
          },
          {
            "type": "command",
            "command": "node .claude/hooks/stopEvent.js 2>/dev/null || true",
            "timeout": 10,
            "statusMessage": "Session metrics..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/userPromptSubmit.js 2>/dev/null || true",
            "timeout": 5,
            "statusMessage": "Context activation..."
          }
        ]
      }
    ]
  }
}
