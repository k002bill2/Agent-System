{
  "react-web-development": {
    "type": "skill",
    "enforcement": "require",
    "priority": "high",
    "description": "React Web component development with TypeScript, Vite, Tailwind CSS, and Zustand. Use when creating UI components, pages, or implementing routing flows.",
    "promptTriggers": {
      "keywords": [
        "react",
        "component",
        "tailwind",
        "zustand",
        "vite",
        "컴포넌트",
        "페이지"
      ],
      "intentPatterns": [
        "(create|add|make).*?(component|page|hook)",
        "(react|리액트).*?(개발|구현)"
      ]
    },
    "fileTriggers": {
      "pathPatterns": [
        "src/dashboard/**/*.tsx",
        "src/dashboard/**/*.ts"
      ]
    }
  },
  "backend-development": {
    "type": "domain",
    "enforcement": "require",
    "priority": "critical",
    "description": "AOS Backend 개발 (FastAPI + LangGraph + Python async). AgentState TypedDict 준수, 노드 함수 async 필수.",
    "promptTriggers": {
      "keywords": [
        "api",
        "endpoint",
        "fastapi",
        "langgraph",
        "agent",
        "service",
        "async",
        "await",
        "orchestrator",
        "백엔드",
        "비동기"
      ],
      "intentPatterns": [
        "(create|add|implement).*?(api|endpoint|service)",
        "(langgraph|orchestrat).*?(node|graph|agent)",
        "(async|비동기).*?(function|함수)"
      ]
    },
    "fileTriggers": {
      "pathPatterns": [
        "src/backend/**/*.py"
      ],
      "contentPatterns": [
        "FastAPI",
        "LangGraph",
        "BaseNode",
        "AgentState",
        "async def",
        "await",
        "asyncio"
      ]
    },
    "reminder": "비동기 패턴 사용, 타입 힌트 필수, pytest 테스트 작성, async def에는 반드시 await 포함"
  },
  "error-handling": {
    "type": "guideline",
    "enforcement": "require",
    "priority": "high",
    "description": "에러 처리 패턴 (Frontend: ErrorBoundary + useErrorHandler, Backend: HTTPException)",
    "promptTriggers": {
      "keywords": [
        "error",
        "catch",
        "try",
        "에러",
        "오류",
        "예외"
      ],
      "intentPatterns": [
        "(handle|catch).*?(error|exception)",
        "try.*?catch"
      ]
    },
    "fileTriggers": {
      "pathPatterns": [
        "**/services/**",
        "**/hooks/**"
      ],
      "contentPatterns": [
        "try",
        "catch",
        "throw",
        "Error"
      ]
    },
    "reminder": "에러는 logger 사용, FastAPI는 HTTPException으로 반환"
  },
  "test-automation": {
    "type": "skill",
    "enforcement": "suggest",
    "priority": "high",
    "description": "Generate comprehensive Vitest tests for React Web components, hooks, and stores. Use when writing tests, improving coverage, or test-driven development.",
    "promptTriggers": {
      "keywords": [
        "test",
        "vitest",
        "coverage",
        "tdd",
        "testing library"
      ],
      "intentPatterns": [
        "(write|add|create).*?test",
        "(run|check).*?coverage",
        "test.*?(component|hook|store)"
      ]
    },
    "fileTriggers": {
      "pathPatterns": [
        "**/__tests__/**",
        "**/*.test.ts",
        "**/*.test.tsx"
      ]
    }
  },
  "zustand-store-patterns": {
    "type": "guideline",
    "enforcement": "require",
    "priority": "high",
    "description": "Zustand 상태 관리 패턴",
    "promptTriggers": {
      "keywords": [
        "zustand",
        "store",
        "상태 관리"
      ],
      "intentPatterns": [
        "(create|add).*?(store|zustand)",
        "(state|상태).*?(management|관리)"
      ]
    },
    "fileTriggers": {
      "pathPatterns": [
        "src/dashboard/src/stores/**/*.ts"
      ],
      "contentPatterns": [
        "create<",
        "useStore",
        "set(",
        "get()"
      ]
    },
    "reminder": "액션과 상태 분리, 셀렉터 사용으로 리렌더링 최적화"
  },
  "mcp-integration": {
    "type": "domain",
    "enforcement": "require",
    "priority": "high",
    "description": "MCP (Model Context Protocol) 통합",
    "promptTriggers": {
      "keywords": [
        "mcp",
        "tool",
        "protocol"
      ],
      "intentPatterns": [
        "(mcp|model context).*?(server|tool)",
        "(add|create).*?(mcp|tool)"
      ]
    },
    "fileTriggers": {
      "pathPatterns": [
        "src/backend/services/mcp_manager.py"
      ],
      "contentPatterns": [
        "MCPManager",
        "MCPToolCall",
        "call_tool"
      ]
    }
  },
  "hitl-approval": {
    "type": "guardrail",
    "enforcement": "require",
    "priority": "critical",
    "description": "Human-in-the-Loop 승인 시스템",
    "promptTriggers": {
      "keywords": [
        "hitl",
        "approval",
        "승인",
        "dangerous"
      ],
      "intentPatterns": [
        "(hitl|human.in.the.loop).*?(approval|check)",
        "(dangerous|risky).*?(operation|action)"
      ]
    },
    "fileTriggers": {
      "pathPatterns": [
        "src/backend/models/hitl.py",
        "src/backend/orchestrator/nodes.py"
      ],
      "contentPatterns": [
        "TOOL_RISK_CONFIG",
        "requires_approval",
        "pending_approvals"
      ]
    },
    "reminder": "HIGH 리스크 도구는 반드시 승인 필요, approval_id 추적 필수"
  },
  "rag-vector-db": {
    "type": "domain",
    "enforcement": "suggest",
    "priority": "normal",
    "description": "RAG + Vector DB 통합",
    "promptTriggers": {
      "keywords": [
        "rag",
        "vector",
        "embedding",
        "semantic search"
      ],
      "intentPatterns": [
        "(rag|vector).*?(search|query)"
      ]
    },
    "fileTriggers": {
      "pathPatterns": [
        "src/backend/services/rag_service.py"
      ],
      "contentPatterns": [
        "embedding",
        "query",
        "index_project"
      ]
    }
  },
  "parallel-coordinator": {
    "type": "workflow",
    "enforcement": "suggest",
    "priority": "high",
    "description": "Coordinate parallel agent execution using ACE Framework for AOS development. Use when implementing features with 3+ independent subtasks (UI + API + Tests).",
    "promptTriggers": {
      "keywords": [
        "parallel",
        "concurrent",
        "multi-agent",
        "coordinate",
        "ACE"
      ],
      "intentPatterns": [
        "(parallel|concurrent).*?(agent|task|execution)",
        "(coordinate|orchestrate).*?(agent|worker)",
        "multi.?agent"
      ]
    }
  },
  "verification-loop": {
    "type": "workflow",
    "enforcement": "suggest",
    "priority": "high",
    "description": "Boris Cherny style verification feedback loop automation. Run type check, lint, test, and build verification.",
    "promptTriggers": {
      "keywords": [
        "verify",
        "verification",
        "feedback loop",
        "check",
        "validate"
      ],
      "intentPatterns": [
        "(verify|validate).*?(code|app)",
        "(feedback|verification).*?loop"
      ]
    }
  },
  "dev-docs-workflow": {
    "type": "workflow",
    "enforcement": "suggest",
    "priority": "high",
    "description": "Dev Docs 3-파일 시스템 워크플로우",
    "promptTriggers": {
      "keywords": [
        "dev docs",
        "plan",
        "대규모 작업"
      ],
      "intentPatterns": [
        "(create|make).*?(dev docs|plan)"
      ]
    },
    "reminder": "대규모 작업 전 /dev-docs 실행 권장, context 20% 이하시 /update-dev-docs"
  },
  "hook-creator": {
    "type": "meta",
    "enforcement": "suggest",
    "priority": "normal",
    "description": "Create and configure Claude Code hooks for customizing agent behavior. Use when the user wants to (1) create a new hook, (2) configure automatic formatting, logging, or notifications, (3) add file protection or custom permissions, (4) set up pre/post tool execution actions, or (5) asks about hook events like PreToolUse, PostToolUse, Notification, etc.",
    "promptTriggers": {
      "keywords": [
        "hook",
        "hooks",
        "PreToolUse",
        "PostToolUse",
        "UserPromptSubmit"
      ],
      "intentPatterns": [
        "(create|make|add).*?hook",
        "(configure|setup).*?hook"
      ]
    },
    "fileTriggers": {
      "pathPatterns": [
        ".claude/hooks/**"
      ]
    }
  },
  "skill-creator": {
    "type": "meta",
    "enforcement": "suggest",
    "priority": "normal",
    "description": "Guide for creating effective skills. This skill should be used when users want to create a new skill (or update an existing skill) that extends Claude's capabilities with specialized knowledge, workflows, or tool integrations.",
    "promptTriggers": {
      "keywords": [
        "skill",
        "create skill",
        "new skill",
        "SKILL.md"
      ],
      "intentPatterns": [
        "(create|make|add).*?skill",
        "(update|modify).*?skill"
      ]
    },
    "fileTriggers": {
      "pathPatterns": [
        ".claude/skills/**"
      ]
    }
  },
  "slash-command-creator": {
    "type": "meta",
    "enforcement": "suggest",
    "priority": "normal",
    "description": "Guide for creating Claude Code slash commands. Use when the user wants to create a new slash command, update an existing slash command, or asks about slash command syntax, frontmatter options, or best practices.",
    "promptTriggers": {
      "keywords": [
        "command",
        "slash command",
        "/command"
      ],
      "intentPatterns": [
        "(create|make|add).*?command",
        "(new|custom).*?slash"
      ]
    },
    "fileTriggers": {
      "pathPatterns": [
        ".claude/commands/**"
      ]
    }
  },
  "subagent-creator": {
    "type": "meta",
    "enforcement": "suggest",
    "priority": "normal",
    "description": "Create specialized Claude Code sub-agents with custom system prompts and tool configurations. Use when users ask to create a new sub-agent, custom agent, specialized assistant, or want to configure task-specific AI workflows for Claude Code.",
    "promptTriggers": {
      "keywords": [
        "agent",
        "subagent",
        "sub-agent",
        "specialist"
      ],
      "intentPatterns": [
        "(create|make|add).*?(agent|subagent)",
        "(new|custom).*?agent"
      ]
    },
    "fileTriggers": {
      "pathPatterns": [
        ".claude/agents/**"
      ]
    }
  },
  "ace-framework": {
    "type": "governance",
    "enforcement": "suggest",
    "priority": "critical",
    "description": "ACE (Autonomous Cognitive Entity) Framework - 4-Pillar governance model for safe, coordinated multi-agent execution. Defines soft constraints (prompts), hard constraints (hooks), boundaries (workspace isolation), and optimization (analytics).",
    "promptTriggers": {
      "keywords": [
        "ACE",
        "governance",
        "constraint",
        "safety",
        "boundary"
      ],
      "intentPatterns": [
        "(ACE|governance).*?(framework|model|pillar)",
        "(soft|hard).*?constraint",
        "(boundary|isolation).*?(agent|workspace)"
      ]
    }
  },
  "agent-improvement": {
    "type": "meta",
    "enforcement": "suggest",
    "priority": "low",
    "description": "Self-improvement loop for multi-agent workflows. Diagnose failures, improve tool descriptions, and learn from success/failure patterns.",
    "promptTriggers": {
      "keywords": [
        "improvement",
        "failure",
        "diagnose",
        "optimize",
        "benchmark"
      ],
      "intentPatterns": [
        "(improve|optimize).*?(agent|workflow)",
        "(diagnose|analyze).*?(failure|error)"
      ]
    }
  },
  "agent-observability": {
    "type": "infrastructure",
    "enforcement": "suggest",
    "priority": "medium",
    "description": "Production tracing and metrics for multi-agent workflows. Track agent decisions, tool calls, and performance without monitoring conversation content.",
    "promptTriggers": {
      "keywords": [
        "trace",
        "metrics",
        "observability",
        "monitoring",
        "performance"
      ],
      "intentPatterns": [
        "(trace|track).*?(agent|workflow)",
        "(monitor|observe).*?(performance|decision)"
      ]
    }
  },
  "cc-feature-implementer-main": {
    "type": "workflow",
    "enforcement": "suggest",
    "priority": "high",
    "description": "Creates phase-based feature plans with quality gates and incremental delivery structure. Use when planning features, organizing work, breaking down tasks, creating roadmaps, or structuring development strategy. Keywords: plan, planning, phases, breakdown, strategy, roadmap, organize, structure, outline.",
    "promptTriggers": {
      "keywords": [
        "plan",
        "planning",
        "phases",
        "roadmap",
        "breakdown"
      ],
      "intentPatterns": [
        "(create|make).*?plan",
        "(break.*?down|structure).*?(task|feature)"
      ]
    }
  },
  "external-memory": {
    "type": "workflow",
    "enforcement": "suggest",
    "priority": "high",
    "description": "Context persistence system for long-running multi-agent tasks. Saves research plans, findings, and checkpoints to prevent context loss at token limits.",
    "promptTriggers": {}
  }
}
