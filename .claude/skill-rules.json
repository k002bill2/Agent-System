{
  "react-web-development": {
    "type": "skill",
    "enforcement": "require",
    "priority": "critical",
    "skillFile": ".claude/skills/react-web-development/SKILL.md",
    "description": "React Web component development with TypeScript, Vite, Tailwind CSS, and Zustand. Includes useEffect cleanup, routing patterns, and performance optimization.",
    "promptTriggers": {
      "keywords": [
        "react", "component", "tailwind", "zustand", "vite",
        "useEffect", "hook", "page", "router", "navigate",
        "컴포넌트", "페이지"
      ],
      "intentPatterns": [
        "(create|add|make).*?(component|page|hook)",
        "(react|리액트).*?(개발|구현)",
        "(navigation|navigate).*?(page|route)"
      ]
    },
    "fileTriggers": {
      "pathPatterns": [
        "src/dashboard/**/*.tsx",
        "src/dashboard/**/*.ts"
      ]
    },
    "reminder": "useEffect에서 구독/타이머는 반드시 cleanup 함수에서 정리하세요"
  },
  "backend-development": {
    "type": "domain",
    "enforcement": "require",
    "priority": "critical",
    "description": "AOS Backend 개발 (FastAPI + LangGraph + Python async). AgentState TypedDict 준수, 노드 함수 async 필수.",
    "promptTriggers": {
      "keywords": [
        "api", "endpoint", "fastapi", "langgraph", "agent", "service",
        "async", "await", "orchestrator", "백엔드", "비동기"
      ],
      "intentPatterns": [
        "(create|add|implement).*?(api|endpoint|service)",
        "(langgraph|orchestrat).*?(node|graph|agent)",
        "(async|비동기).*?(function|함수)"
      ]
    },
    "fileTriggers": {
      "pathPatterns": [
        "src/backend/**/*.py"
      ],
      "contentPatterns": [
        "FastAPI", "LangGraph", "BaseNode", "AgentState",
        "async def", "await", "asyncio"
      ]
    },
    "reminder": "비동기 패턴 사용, 타입 힌트 필수, pytest 테스트 작성, async def에는 반드시 await 포함"
  },
  "error-handling": {
    "type": "guideline",
    "enforcement": "require",
    "priority": "high",
    "description": "에러 처리 패턴 (Frontend: ErrorBoundary + useErrorHandler, Backend: HTTPException)",
    "promptTriggers": {
      "keywords": [
        "error", "catch", "try", "에러", "오류", "예외"
      ],
      "intentPatterns": [
        "(handle|catch).*?(error|exception)",
        "try.*?catch"
      ]
    },
    "fileTriggers": {
      "pathPatterns": ["**/services/**", "**/hooks/**"],
      "contentPatterns": ["try", "catch", "throw", "Error"]
    },
    "reminder": "에러는 logger 사용, FastAPI는 HTTPException으로 반환"
  },
  "test-automation": {
    "type": "skill",
    "enforcement": "suggest",
    "priority": "high",
    "skillFile": ".claude/skills/test-automation/SKILL.md",
    "description": "Generate comprehensive Vitest tests. Coverage targets: statements 75%, functions 70%, branches 60%.",
    "promptTriggers": {
      "keywords": [
        "test", "vitest", "coverage", "tdd", "testing library",
        "테스트", "커버리지"
      ],
      "intentPatterns": [
        "(write|add|create).*?test",
        "(run|check).*?coverage"
      ]
    },
    "fileTriggers": {
      "pathPatterns": [
        "**/__tests__/**", "**/*.test.ts", "**/*.test.tsx"
      ]
    },
    "thresholds": {
      "statements": 75,
      "functions": 70,
      "branches": 60
    }
  },
  "zustand-store-patterns": {
    "type": "guideline",
    "enforcement": "require",
    "priority": "high",
    "description": "Zustand 상태 관리 패턴",
    "promptTriggers": {
      "keywords": ["zustand", "store", "상태 관리"],
      "intentPatterns": [
        "(create|add).*?(store|zustand)",
        "(state|상태).*?(management|관리)"
      ]
    },
    "fileTriggers": {
      "pathPatterns": ["src/dashboard/src/stores/**/*.ts"],
      "contentPatterns": ["create<", "useStore", "set(", "get()"]
    },
    "reminder": "액션과 상태 분리, 셀렉터 사용으로 리렌더링 최적화"
  },
  "mcp-integration": {
    "type": "domain",
    "enforcement": "require",
    "priority": "high",
    "description": "MCP (Model Context Protocol) 통합",
    "promptTriggers": {
      "keywords": ["mcp", "tool", "protocol"],
      "intentPatterns": [
        "(mcp|model context).*?(server|tool)",
        "(add|create).*?(mcp|tool)"
      ]
    },
    "fileTriggers": {
      "pathPatterns": ["src/backend/services/mcp_manager.py"],
      "contentPatterns": ["MCPManager", "MCPToolCall", "call_tool"]
    }
  },
  "hitl-approval": {
    "type": "guardrail",
    "enforcement": "require",
    "priority": "critical",
    "description": "Human-in-the-Loop 승인 시스템",
    "promptTriggers": {
      "keywords": ["hitl", "approval", "승인", "dangerous"],
      "intentPatterns": [
        "(hitl|human.in.the.loop).*?(approval|check)",
        "(dangerous|risky).*?(operation|action)"
      ]
    },
    "fileTriggers": {
      "pathPatterns": ["src/backend/models/hitl.py", "src/backend/orchestrator/nodes.py"],
      "contentPatterns": ["TOOL_RISK_CONFIG", "requires_approval", "pending_approvals"]
    },
    "reminder": "HIGH 리스크 도구는 반드시 승인 필요, approval_id 추적 필수"
  },
  "rag-vector-db": {
    "type": "domain",
    "enforcement": "suggest",
    "priority": "normal",
    "description": "RAG + Vector DB 통합",
    "promptTriggers": {
      "keywords": ["rag", "vector", "embedding", "semantic search"],
      "intentPatterns": ["(rag|vector).*?(search|query)"]
    },
    "fileTriggers": {
      "pathPatterns": ["src/backend/services/rag_service.py"],
      "contentPatterns": ["embedding", "query", "index_project"]
    }
  },
  "parallel-coordinator": {
    "type": "workflow",
    "enforcement": "suggest",
    "priority": "high",
    "skillFile": ".claude/skills/parallel-coordinator/SKILL.md",
    "description": "Coordinate parallel agent execution using ACE Framework for AOS development.",
    "promptTriggers": {
      "keywords": ["parallel", "concurrent", "multi-agent", "ACE"],
      "intentPatterns": [
        "(parallel|concurrent).*?(agent|task|execution)",
        "multi.?agent"
      ]
    }
  },
  "verification-loop": {
    "type": "workflow",
    "enforcement": "suggest",
    "priority": "high",
    "skillFile": ".claude/skills/verification-loop/SKILL.md",
    "description": "Boris Cherny style verification feedback loop. Type check, lint, test, and build.",
    "promptTriggers": {
      "keywords": ["verify", "verification", "feedback loop", "validate"],
      "intentPatterns": ["(verify|validate).*?(code|app)"]
    }
  },
  "dev-docs-workflow": {
    "type": "workflow",
    "enforcement": "suggest",
    "priority": "high",
    "description": "Dev Docs 3-파일 시스템 워크플로우",
    "promptTriggers": {
      "keywords": ["dev docs", "plan", "대규모 작업"],
      "intentPatterns": ["(create|make).*?(dev docs|plan)"]
    },
    "reminder": "대규모 작업 전 /dev-docs 실행 권장, context 20% 이하시 /update-dev-docs"
  },
  "hook-creator": {
    "type": "meta",
    "enforcement": "suggest",
    "priority": "normal",
    "description": "Create and configure Claude Code hooks.",
    "promptTriggers": {
      "keywords": ["hook", "hooks", "PreToolUse", "PostToolUse"],
      "intentPatterns": ["(create|make|add).*?hook"]
    },
    "fileTriggers": {
      "pathPatterns": [".claude/hooks/**"]
    }
  },
  "skill-creator": {
    "type": "meta",
    "enforcement": "suggest",
    "priority": "normal",
    "description": "Guide for creating effective skills.",
    "promptTriggers": {
      "keywords": ["skill", "create skill", "SKILL.md"],
      "intentPatterns": ["(create|make|add|update).*?skill"]
    },
    "fileTriggers": {
      "pathPatterns": [".claude/skills/**"]
    }
  },
  "slash-command-creator": {
    "type": "meta",
    "enforcement": "suggest",
    "priority": "normal",
    "description": "Guide for creating Claude Code slash commands.",
    "promptTriggers": {
      "keywords": ["command", "slash command"],
      "intentPatterns": ["(create|make|add).*?command"]
    },
    "fileTriggers": {
      "pathPatterns": [".claude/commands/**"]
    }
  },
  "subagent-creator": {
    "type": "meta",
    "enforcement": "suggest",
    "priority": "normal",
    "description": "Create specialized Claude Code sub-agents.",
    "promptTriggers": {
      "keywords": ["agent", "subagent", "specialist"],
      "intentPatterns": ["(create|make|add).*?(agent|subagent)"]
    },
    "fileTriggers": {
      "pathPatterns": [".claude/agents/**"]
    }
  }
}
