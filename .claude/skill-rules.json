{
  "react-web-patterns": {
    "type": "guideline",
    "enforcement": "require",
    "priority": "critical",
    "description": "React Web/Tailwind CSS 핵심 패턴 가이드",
    "promptTriggers": {
      "keywords": ["useEffect", "component", "page", "hook", "tailwind", "컴포넌트", "페이지"],
      "intentPatterns": [
        "(create|add|make).*?(component|page|hook)",
        "(fix|debug).*?(useEffect|hook)",
        "(생성|만들|추가).*?(컴포넌트|페이지|훅)"
      ]
    },
    "fileTriggers": {
      "pathPatterns": ["**/components/**/*.tsx", "**/pages/**/*.tsx", "**/hooks/**/*.ts"],
      "contentPatterns": ["useEffect", "useState", "React.FC", "className"]
    }
  },

  "useeffect-cleanup": {
    "type": "guardrail",
    "enforcement": "require",
    "priority": "critical",
    "description": "useEffect cleanup 함수 필수 확인",
    "promptTriggers": {
      "keywords": ["useEffect", "subscription", "interval", "listener", "구독", "타이머"],
      "intentPatterns": [
        "useEffect.*?(subscribe|interval|timer|listener)",
        "(add|remove).*?(subscription|listener)"
      ]
    },
    "reminder": "useEffect에서 구독/타이머는 반드시 cleanup 함수에서 정리하세요"
  },

  "firebase-integration": {
    "type": "domain",
    "enforcement": "require",
    "priority": "high",
    "description": "Firebase 통합 패턴 (Auth, Firestore)",
    "promptTriggers": {
      "keywords": ["firebase", "firestore", "auth", "인증", "데이터베이스"],
      "intentPatterns": [
        "(firebase|firestore).*?(setup|config|integration)",
        "(auth|인증).*?(login|signup|logout)"
      ]
    },
    "fileTriggers": {
      "pathPatterns": ["**/services/firebase/**", "**/services/auth/**"],
      "contentPatterns": ["firebase", "firestore", "auth"]
    }
  },

  "seoul-api-integration": {
    "type": "domain",
    "enforcement": "require",
    "priority": "critical",
    "description": "Seoul Open Data API 통합 패턴",
    "promptTriggers": {
      "keywords": ["seoul api", "서울 api", "실시간 도착", "arrival", "subway", "지하철"],
      "intentPatterns": [
        "(seoul|서울).*?(api|데이터)",
        "(실시간|realtime).*?(arrival|도착)",
        "(fetch|get).*?(train|subway)"
      ]
    },
    "fileTriggers": {
      "pathPatterns": ["**/services/api/**", "**/seoulSubwayApi.ts"],
      "contentPatterns": ["seoulSubwayApi", "ARRIVAL_INFO", "STATION"]
    },
    "reminder": "API 폴링 간격은 최소 30초를 유지하세요"
  },

  "routing-patterns": {
    "type": "guideline",
    "enforcement": "suggest",
    "priority": "high",
    "description": "React Router 패턴",
    "promptTriggers": {
      "keywords": ["router", "navigate", "page", "route", "link", "라우팅"],
      "intentPatterns": [
        "(navigation|navigate).*?(page|route)",
        "(add|create).*?(page|route)"
      ]
    },
    "fileTriggers": {
      "pathPatterns": ["**/pages/**", "**/App.tsx"],
      "contentPatterns": ["useNavigate", "useParams", "Route", "BrowserRouter"]
    }
  },

  "typescript-strict": {
    "type": "guardrail",
    "enforcement": "block",
    "priority": "critical",
    "description": "TypeScript strict mode 준수",
    "promptTriggers": {
      "keywords": ["any", "타입", "type", "interface"],
      "intentPatterns": [
        ".*?:\\s*any\\b",
        "(add|define).*?(type|interface)"
      ]
    },
    "blockedPatterns": [
      ": any",
      "as any"
    ],
    "reminder": "any 타입 대신 구체적인 타입이나 unknown을 사용하세요"
  },

  "error-handling": {
    "type": "guideline",
    "enforcement": "require",
    "priority": "high",
    "description": "에러 처리 및 Sentry 통합",
    "promptTriggers": {
      "keywords": ["error", "catch", "try", "에러", "오류", "예외"],
      "intentPatterns": [
        "(handle|catch).*?(error|exception)",
        "try.*?catch"
      ]
    },
    "fileTriggers": {
      "pathPatterns": ["**/services/**", "**/hooks/**"],
      "contentPatterns": ["try", "catch", "throw", "Error"]
    },
    "reminder": "에러는 빈 배열/null 반환으로 처리하고, Sentry로 전송하세요"
  },

  "async-storage": {
    "type": "domain",
    "enforcement": "suggest",
    "priority": "normal",
    "description": "AsyncStorage 캐싱 패턴",
    "promptTriggers": {
      "keywords": ["storage", "cache", "persist", "캐시", "저장"],
      "intentPatterns": [
        "(async)?storage.*?(save|get|set)",
        "(cache|persist).*?(data|state)"
      ]
    },
    "fileTriggers": {
      "pathPatterns": ["**/utils/storageUtils.ts", "**/services/data/**"],
      "contentPatterns": ["AsyncStorage", "setItem", "getItem"]
    }
  },

  "test-coverage": {
    "type": "validation",
    "enforcement": "require",
    "priority": "high",
    "description": "Vitest 테스트 커버리지 (75% statements)",
    "promptTriggers": {
      "keywords": ["test", "vitest", "coverage", "테스트", "커버리지"],
      "intentPatterns": [
        "(write|add).*?test",
        "(run|check).*?coverage"
      ]
    },
    "fileTriggers": {
      "pathPatterns": ["**/__tests__/**", "**/*.test.ts", "**/*.test.tsx"],
      "contentPatterns": ["describe", "it", "expect", "vi.fn"]
    },
    "thresholds": {
      "statements": 75,
      "functions": 70,
      "branches": 60
    }
  },

  "performance-optimization": {
    "type": "guideline",
    "enforcement": "suggest",
    "priority": "normal",
    "description": "React Web 성능 최적화",
    "promptTriggers": {
      "keywords": ["performance", "optimize", "memo", "callback", "성능", "최적화"],
      "intentPatterns": [
        "(optimize|improve).*?(performance|speed)",
        "(use)?memo.*?(component|function)"
      ]
    },
    "fileTriggers": {
      "pathPatterns": ["**/components/**"],
      "contentPatterns": ["React.memo", "useMemo", "useCallback", "React.lazy"]
    }
  },

  "checklist-generator": {
    "type": "tool",
    "enforcement": "suggest",
    "priority": "normal",
    "description": "자동 체크리스트 생성",
    "promptTriggers": {
      "keywords": ["checklist", "체크리스트", "TODO", "확인사항"],
      "intentPatterns": [
        "(create|generate).*?(checklist|todo)",
        "(verify|check).*?list"
      ]
    }
  },

  "code-simplifier": {
    "type": "agent",
    "enforcement": "suggest",
    "priority": "normal",
    "description": "코드 단순화 및 리팩토링",
    "agentFile": ".claude/agents/code-simplifier.md",
    "model": "haiku",
    "promptTriggers": {
      "keywords": ["simplify", "refactor", "단순화", "리팩토링", "개선"],
      "intentPatterns": [
        "(simplify|refactor).*?(code|function)",
        "(reduce|줄이).*?(complexity|복잡도)"
      ]
    }
  },

  "parallel-coordinator": {
    "type": "framework",
    "enforcement": "suggest",
    "priority": "high",
    "description": "병렬 에이전트 조정",
    "promptTriggers": {
      "keywords": ["parallel", "병렬", "동시", "concurrent", "에이전트"],
      "intentPatterns": [
        "(parallel|병렬).*?(task|작업)",
        "(coordinate|조정).*?(agent|에이전트)"
      ]
    }
  },

  "backend-development": {
    "type": "domain",
    "enforcement": "require",
    "priority": "high",
    "description": "AOS Backend 개발 (FastAPI + LangGraph)",
    "promptTriggers": {
      "keywords": ["api", "endpoint", "fastapi", "langgraph", "agent", "service", "백엔드", "orchestrator"],
      "intentPatterns": [
        "(create|add|implement).*?(api|endpoint|service)",
        "(langgraph|orchestrat).*?(node|graph|agent)",
        "(backend|서버).*?(개발|구현)"
      ]
    },
    "fileTriggers": {
      "pathPatterns": ["src/backend/**/*.py"],
      "contentPatterns": ["FastAPI", "LangGraph", "BaseNode", "AgentState"]
    },
    "reminder": "비동기 패턴 사용, 타입 힌트 필수, pytest 테스트 작성"
  },

  "langgraph-patterns": {
    "type": "guideline",
    "enforcement": "require",
    "priority": "critical",
    "description": "LangGraph 오케스트레이션 패턴",
    "promptTriggers": {
      "keywords": ["langgraph", "node", "graph", "state", "orchestrator", "오케스트레이션"],
      "intentPatterns": [
        "(create|add).*?(node|graph)",
        "(implement|구현).*?(orchestrat|오케스트레이션)"
      ]
    },
    "fileTriggers": {
      "pathPatterns": ["src/backend/orchestrator/**/*.py", "src/backend/agents/**/*.py"],
      "contentPatterns": ["StateGraph", "add_node", "add_edge", "AgentState"]
    },
    "reminder": "AgentState TypedDict 준수, 노드 함수 async 필수, 에러 핸들링 철저히"
  },

  "python-async-patterns": {
    "type": "guardrail",
    "enforcement": "require",
    "priority": "critical",
    "description": "Python 비동기 패턴 가이드",
    "promptTriggers": {
      "keywords": ["async", "await", "asyncio", "비동기", "concurrent"],
      "intentPatterns": [
        "(async|비동기).*?(function|함수)",
        "asyncio.*?(gather|create_task)"
      ]
    },
    "fileTriggers": {
      "pathPatterns": ["src/backend/**/*.py"],
      "contentPatterns": ["async def", "await", "asyncio"]
    },
    "reminder": "async def에는 반드시 await 포함, 동기 함수 혼용 금지, try-except로 에러 처리"
  },

  "mcp-integration": {
    "type": "domain",
    "enforcement": "require",
    "priority": "high",
    "description": "MCP (Model Context Protocol) 통합",
    "promptTriggers": {
      "keywords": ["mcp", "tool", "server", "protocol"],
      "intentPatterns": [
        "(mcp|model context).*?(server|tool)",
        "(add|create).*?(mcp|tool)"
      ]
    },
    "fileTriggers": {
      "pathPatterns": ["src/backend/services/mcp_manager.py", "**/*.mcp.json"],
      "contentPatterns": ["MCPManager", "MCPToolCall", "call_tool"]
    }
  },

  "hitl-approval": {
    "type": "guardrail",
    "enforcement": "require",
    "priority": "critical",
    "description": "Human-in-the-Loop 승인 시스템",
    "promptTriggers": {
      "keywords": ["hitl", "approval", "승인", "human-in-the-loop", "dangerous", "위험"],
      "intentPatterns": [
        "(hitl|human.in.the.loop).*?(approval|check)",
        "(dangerous|risky).*?(operation|action)"
      ]
    },
    "fileTriggers": {
      "pathPatterns": ["src/backend/models/hitl.py", "src/backend/orchestrator/nodes.py"],
      "contentPatterns": ["TOOL_RISK_CONFIG", "requires_approval", "pending_approvals"]
    },
    "reminder": "HIGH 리스크 도구는 반드시 승인 필요, approval_id 추적 필수"
  },

  "zustand-store-patterns": {
    "type": "guideline",
    "enforcement": "require",
    "priority": "high",
    "description": "Zustand 상태 관리 패턴",
    "promptTriggers": {
      "keywords": ["zustand", "store", "상태 관리", "state management"],
      "intentPatterns": [
        "(create|add).*?(store|zustand)",
        "(state|상태).*?(management|관리)"
      ]
    },
    "fileTriggers": {
      "pathPatterns": ["src/dashboard/src/stores/**/*.ts"],
      "contentPatterns": ["create<", "useStore", "set(", "get()"]
    },
    "reminder": "immer 미들웨어 권장, 액션과 상태 분리, 셀렉터 사용으로 리렌더링 최적화"
  },

  "rag-vector-db": {
    "type": "domain",
    "enforcement": "suggest",
    "priority": "normal",
    "description": "RAG + Vector DB 통합",
    "promptTriggers": {
      "keywords": ["rag", "vector", "chromadb", "embedding", "semantic search"],
      "intentPatterns": [
        "(rag|vector).*?(search|query)",
        "(semantic|의미론적).*?(search|검색)"
      ]
    },
    "fileTriggers": {
      "pathPatterns": ["src/backend/services/rag_service.py"],
      "contentPatterns": ["ChromaDB", "embedding", "query", "index_project"]
    }
  },

  "dev-docs-workflow": {
    "type": "workflow",
    "enforcement": "suggest",
    "priority": "high",
    "description": "Dev Docs 3-파일 시스템 워크플로우",
    "promptTriggers": {
      "keywords": ["dev docs", "plan", "context", "대규모 작업", "큰 작업"],
      "intentPatterns": [
        "(create|make).*?(dev docs|plan)",
        "(large|big|대규모).*?(task|작업|feature)"
      ]
    },
    "reminder": "대규모 작업 전 /dev-docs 실행 권장, context 20% 이하시 /update-dev-docs"
  }
}
