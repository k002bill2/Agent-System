{
  "react-web-development": {
    "type": "skill",
    "enforcement": "require",
    "priority": "high",
    "description": "React Web component development with TypeScript, Vite, Tailwind CSS, and Zustand. Use when creating UI components, pages, or implementing routing flows.",
    "promptTriggers": {
      "keywords": [
        "react",
        "component",
        "tailwind",
        "zustand",
        "vite",
        "컴포넌트",
        "페이지"
      ],
      "intentPatterns": [
        "(create|add|make).*?(component|page|hook)",
        "(react|리액트).*?(개발|구현)"
      ]
    },
    "fileTriggers": {
      "pathPatterns": [
        "src/dashboard/**/*.tsx",
        "src/dashboard/**/*.ts"
      ]
    },
    "reminder": "memo()+displayName 필수, cn() 유틸리티, useEffect cleanup, 커버리지 75%+ 목표, Tailwind 전용 (인라인 금지)"
  },
  "backend-development": {
    "type": "domain",
    "enforcement": "require",
    "priority": "critical",
    "description": "AOS Backend 개발 (FastAPI + LangGraph + Python async). AgentState TypedDict 준수, 노드 함수 async 필수.",
    "promptTriggers": {
      "keywords": [
        "api",
        "endpoint",
        "fastapi",
        "langgraph",
        "agent",
        "service",
        "async",
        "await",
        "orchestrator",
        "백엔드",
        "비동기"
      ],
      "intentPatterns": [
        "(create|add|implement).*?(api|endpoint|service)",
        "(langgraph|orchestrat).*?(node|graph|agent)",
        "(async|비동기).*?(function|함수)"
      ]
    },
    "fileTriggers": {
      "pathPatterns": [
        "src/backend/**/*.py"
      ],
      "contentPatterns": [
        "FastAPI",
        "LangGraph",
        "BaseNode",
        "AgentState",
        "async def",
        "await",
        "asyncio"
      ]
    },
    "reminder": "비동기 패턴 사용, 타입 힌트 필수, pytest 테스트 작성, async def에는 반드시 await 포함"
  },
  "error-handling": {
    "type": "guideline",
    "enforcement": "require",
    "priority": "high",
    "description": "에러 처리 패턴 (Frontend: ErrorBoundary + useErrorHandler, Backend: HTTPException)",
    "promptTriggers": {
      "keywords": [
        "error",
        "catch",
        "try",
        "에러",
        "오류",
        "예외"
      ],
      "intentPatterns": [
        "(handle|catch).*?(error|exception)",
        "try.*?catch"
      ]
    },
    "fileTriggers": {
      "pathPatterns": [
        "**/services/**",
        "**/hooks/**"
      ],
      "contentPatterns": [
        "try",
        "catch",
        "throw",
        "Error"
      ]
    },
    "reminder": "에러는 logger 사용, FastAPI는 HTTPException으로 반환"
  },
  "test-automation": {
    "type": "skill",
    "enforcement": "suggest",
    "priority": "high",
    "description": "Generate comprehensive Vitest tests for React Web components, hooks, and stores. Use when writing tests, improving coverage, or test-driven development.",
    "promptTriggers": {
      "keywords": [
        "test",
        "vitest",
        "coverage",
        "tdd",
        "testing library"
      ],
      "intentPatterns": [
        "(write|add|create).*?test",
        "(run|check).*?coverage",
        "test.*?(component|hook|store)"
      ]
    },
    "fileTriggers": {
      "pathPatterns": [
        "**/__tests__/**",
        "**/*.test.ts",
        "**/*.test.tsx"
      ]
    }
  },
  "zustand-store-patterns": {
    "type": "guideline",
    "enforcement": "require",
    "priority": "high",
    "description": "Zustand 상태 관리 패턴",
    "promptTriggers": {
      "keywords": [
        "zustand",
        "store",
        "상태 관리"
      ],
      "intentPatterns": [
        "(create|add).*?(store|zustand)",
        "(state|상태).*?(management|관리)"
      ]
    },
    "fileTriggers": {
      "pathPatterns": [
        "src/dashboard/src/stores/**/*.ts"
      ],
      "contentPatterns": [
        "create<",
        "useStore",
        "set(",
        "get()"
      ]
    },
    "reminder": "액션과 상태 분리, 셀렉터 사용으로 리렌더링 최적화"
  },
  "mcp-integration": {
    "type": "domain",
    "enforcement": "require",
    "priority": "high",
    "description": "MCP (Model Context Protocol) 통합",
    "promptTriggers": {
      "keywords": [
        "mcp",
        "tool",
        "protocol"
      ],
      "intentPatterns": [
        "(mcp|model context).*?(server|tool)",
        "(add|create).*?(mcp|tool)"
      ]
    },
    "fileTriggers": {
      "pathPatterns": [
        "src/backend/services/mcp_manager.py"
      ],
      "contentPatterns": [
        "MCPManager",
        "MCPToolCall",
        "call_tool"
      ]
    }
  },
  "hitl-approval": {
    "type": "guardrail",
    "enforcement": "require",
    "priority": "critical",
    "description": "Human-in-the-Loop 승인 시스템",
    "promptTriggers": {
      "keywords": [
        "hitl",
        "approval",
        "승인",
        "dangerous"
      ],
      "intentPatterns": [
        "(hitl|human.in.the.loop).*?(approval|check)",
        "(dangerous|risky).*?(operation|action)"
      ]
    },
    "fileTriggers": {
      "pathPatterns": [
        "src/backend/models/hitl.py",
        "src/backend/orchestrator/nodes.py"
      ],
      "contentPatterns": [
        "TOOL_RISK_CONFIG",
        "requires_approval",
        "pending_approvals"
      ]
    },
    "reminder": "HIGH 리스크 도구는 반드시 승인 필요, approval_id 추적 필수"
  },
  "rag-vector-db": {
    "type": "domain",
    "enforcement": "suggest",
    "priority": "normal",
    "description": "RAG + Vector DB 통합",
    "promptTriggers": {
      "keywords": [
        "rag",
        "vector",
        "embedding",
        "semantic search"
      ],
      "intentPatterns": [
        "(rag|vector).*?(search|query)"
      ]
    },
    "fileTriggers": {
      "pathPatterns": [
        "src/backend/services/rag_service.py"
      ],
      "contentPatterns": [
        "embedding",
        "query",
        "index_project"
      ]
    }
  },
  "parallel-coordinator": {
    "type": "workflow",
    "enforcement": "suggest",
    "priority": "high",
    "description": "Coordinate parallel agent execution using ACE Framework for AOS development. Use when implementing features with 3+ independent subtasks (UI + API + Tests).",
    "promptTriggers": {
      "keywords": [
        "parallel",
        "concurrent",
        "multi-agent",
        "coordinate",
        "ACE"
      ],
      "intentPatterns": [
        "(parallel|concurrent).*?(agent|task|execution)",
        "(coordinate|orchestrate).*?(agent|worker)",
        "multi.?agent"
      ]
    }
  },
  "verification-loop": {
    "type": "workflow",
    "enforcement": "suggest",
    "priority": "high",
    "description": "Boris Cherny style verification feedback loop automation. Run type check, lint, test, and build verification.",
    "promptTriggers": {
      "keywords": [
        "verify",
        "verification",
        "feedback loop",
        "check",
        "validate"
      ],
      "intentPatterns": [
        "(verify|validate).*?(code|app)",
        "(feedback|verification).*?loop"
      ]
    }
  },
  "dev-docs-workflow": {
    "type": "workflow",
    "enforcement": "suggest",
    "priority": "high",
    "description": "Dev Docs 3-파일 시스템 워크플로우",
    "promptTriggers": {
      "keywords": [
        "dev docs",
        "plan",
        "대규모 작업"
      ],
      "intentPatterns": [
        "(create|make).*?(dev docs|plan)"
      ]
    },
    "reminder": "대규모 작업 전 /dev-docs 실행 권장, context 20% 이하시 /update-dev-docs"
  },
  "cc-feature-implementer-main": {
    "type": "workflow",
    "enforcement": "suggest",
    "priority": "high",
    "description": "Creates phase-based feature plans with quality gates and incremental delivery structure. Use when planning features, organizing work, breaking down tasks, creating roadmaps, or structuring development strategy. Keywords: plan, planning, phases, breakdown, strategy, roadmap, organize, structure, outline.",
    "promptTriggers": {
      "keywords": [
        "plan",
        "planning",
        "phases",
        "roadmap",
        "breakdown"
      ],
      "intentPatterns": [
        "(create|make).*?plan",
        "(break.*?down|structure).*?(task|feature)"
      ]
    }
  },
  "manage-skills": {
    "type": "skill",
    "enforcement": "suggest",
    "priority": "normal",
    "description": "스킬 생성, 수정, 삭제, 목록 관리. 새 스킬을 만들거나 기존 스킬을 관리할 때 사용.",
    "promptTriggers": {
      "keywords": [
        "스킬 관리",
        "스킬 생성",
        "스킬 목록",
        "manage skill",
        "create skill"
      ],
      "intentPatterns": [
        "(create|manage|list|delete).*?skill",
        "(스킬|skill).*?(만들|생성|관리|삭제)"
      ]
    }
  },
  "port-conflict-check": {
    "type": "skill",
    "enforcement": "suggest",
    "priority": "normal",
    "description": "Docker 포트 충돌 감지. 서비스 시작 전 또는 docker-compose 포트 매핑 변경 시 사용.",
    "promptTriggers": {
      "keywords": [
        "port",
        "conflict",
        "포트",
        "충돌",
        "address already in use"
      ],
      "intentPatterns": [
        "port.*?(conflict|check|충돌)",
        "address.*?already.*?in.*?use",
        "(docker|서비스).*?(start|시작)"
      ]
    }
  },
  "posthog": {
    "type": "skill",
    "enforcement": "suggest",
    "priority": "normal",
    "description": "PostHog 또는 커스텀 분석 이벤트 트래킹 검증. 이벤트 추가/검증 시 사용.",
    "promptTriggers": {
      "keywords": [
        "posthog",
        "analytics",
        "tracking",
        "event",
        "분석"
      ],
      "intentPatterns": [
        "(posthog|analytics).*?(event|track)",
        "(add|verify).*?(event|tracking)"
      ]
    }
  },
  "verify-implementation": {
    "type": "skill",
    "enforcement": "suggest",
    "priority": "high",
    "description": "구현 완료 후 검증. 코드 변경사항이 요구사항을 충족하는지 확인.",
    "promptTriggers": {
      "keywords": [
        "verify",
        "검증",
        "확인",
        "implementation",
        "구현 확인"
      ],
      "intentPatterns": [
        "verify.*?implementation",
        "(구현|변경).*?(검증|확인|완료)"
      ]
    }
  },
  "verify-frontend": {
    "type": "skill",
    "enforcement": "suggest",
    "priority": "high",
    "description": "React/TypeScript/Tailwind 프론트엔드 패턴 검증. 컴포넌트 구현 후, PR 전 사용.",
    "promptTriggers": {
      "keywords": [
        "verify frontend",
        "프론트엔드 검증",
        "컴포넌트 검증"
      ],
      "intentPatterns": [
        "verify.*?frontend",
        "(프론트엔드|컴포넌트).*?검증"
      ]
    },
    "fileTriggers": {
      "pathPatterns": [
        "src/dashboard/src/**/*.tsx"
      ]
    }
  },
  "merge-worktree": {
    "type": "workflow",
    "enforcement": "suggest",
    "priority": "normal",
    "description": "Git worktree 브랜치를 squash-merge하여 깔끔한 커밋 메시지 생성",
    "promptTriggers": {
      "keywords": ["worktree", "merge", "squash", "워크트리"],
      "intentPatterns": ["(merge|squash).*?worktree", "worktree.*?(완료|merge|정리)"]
    }
  },
  "verify-backend": {
    "type": "skill",
    "enforcement": "suggest",
    "priority": "high",
    "description": "Python/FastAPI/LangGraph 백엔드 패턴 검증. API 구현 후, PR 전 사용.",
    "promptTriggers": {
      "keywords": [
        "verify backend",
        "백엔드 검증",
        "API 검증"
      ],
      "intentPatterns": [
        "verify.*?backend",
        "(백엔드|API).*?검증"
      ]
    },
    "fileTriggers": {
      "pathPatterns": [
        "src/backend/**/*.py"
      ]
    }
  }
}
