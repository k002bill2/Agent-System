  "test-coverage": {
    "type": "validation",
    "enforcement": "require",
    "priority": "high",
    "description": "Vitest 테스트 커버리지 (75% statements)",
    "promptTriggers": {
      "keywords": [
        "test",
        "vitest",
        "coverage",
        "테스트",
        "커버리지"
      ],
      "intentPatterns": [
        "(write|add).*?test",
        "(run|check).*?coverage"
      ]
    },
    "fileTriggers": {
      "pathPatterns": [
        "**/__tests__/**",
        "**/*.test.ts",
        "**/*.test.tsx"
      ],
      "contentPatterns": [
        "describe",
        "it",
        "expect",
        "vi.fn"
      ]
    },
    "thresholds": {
      "statements": 75,
      "functions": 70,
      "branches": 60
    }
  },
