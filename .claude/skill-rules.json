  "routing-patterns": {
    "type": "guideline",
    "enforcement": "suggest",
    "priority": "high",
    "description": "React Router 패턴",
    "promptTriggers": {
      "keywords": [
        "router",
        "navigate",
        "page",
        "route",
        "link",
