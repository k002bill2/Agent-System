{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/ethicalValidator.js",
            "timeout": 3,
            "statusMessage": "Security check..."
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -c \"import json,sys; p=json.load(sys.stdin).get('tool_input',{}).get('file_path',''); blocked=['.env','secrets','.git/','/prod/','credentials','private_key','id_rsa','.pem']; sys.exit(2 if any(b in p for b in blocked) else 0)\"",
            "timeout": 5,
            "statusMessage": "Path protection..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/verificationGuard.js 2>/dev/null || true",
            "timeout": 10,
            "statusMessage": "Verification check..."
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/agentLearnings.js 2>/dev/null || true",
            "timeout": 5,
            "statusMessage": "Saving learnings..."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/evalCleanup.js 2>/dev/null || true",
            "timeout": 5,
            "statusMessage": "Eval cleanup..."
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/evalCleanup.js 2>/dev/null || true",
            "timeout": 5,
            "statusMessage": "Eval cleanup..."
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.message' | xargs -I{} osascript -e 'display notification \"{}\" with title \"Claude Code\"'",
            "timeout": 5,
            "statusMessage": "Notifying..."
          }
        ]
      }
    ]
  }
}
