{
  "skill_id": "agent-observability",
  "skill_name": "Agent Observability",
  "type": "workflow_meta",
  "test_method": "with_skill",
  "description": "에이전트 트레이스 데이터 파싱 및 KPI 산출 정확도 측정",
  "scoring": {
    "dimensions": ["event_parsing", "kpi_calculation", "privacy_compliance", "metric_derivation"],
    "pass_threshold": 0.7
  },
  "evals": [
    {
      "id": "ao_001",
      "name": "이벤트 로그 분석",
      "setup": "Create mock events.jsonl with 10 events (5 spawned, 5 completed: 4 success, 1 failure)",
      "prompt": "최근 세션의 에이전트 이벤트를 분석하고 KPI를 산출해주세요.",
      "expected_behavior": {
        "must_calculate": ["success_rate: 80%", "avg_duration", "failure_count: 1", "total_agents: 5"],
        "must_not_log": ["prompt content", "response content", "PII"]
      },
      "grading": {
        "event_parsing": { "weight": 30, "check": "correctly parses all 10 JSONL events" },
        "kpi_calculation": { "weight": 35, "check": "success rate, avg duration, failure count accurate" },
        "privacy_compliance": { "weight": 20, "check": "no prompt/response content in output" },
        "metric_derivation": { "weight": 15, "check": "derives background_ratio, agent_utilization" }
      }
    },
    {
      "id": "ao_002",
      "name": "실패 패턴 그룹화",
      "setup": "Create events.jsonl with 20 events including 5 failures grouped by 2 patterns",
      "prompt": "에이전트 실패 패턴을 분석하고 그룹화해주세요.",
      "expected_behavior": {
        "must_group": ["failures by agent_type", "failures by description keywords"],
        "must_report": ["pattern frequency", "affected agents"]
      },
      "grading": {
        "pattern_grouping": { "weight": 40, "check": "correctly groups 5 failures into 2 patterns" },
        "frequency_analysis": { "weight": 30, "check": "reports count per pattern" },
        "actionable_output": { "weight": 30, "check": "links to agent-improvement for fix suggestions" }
      }
    }
  ]
}
