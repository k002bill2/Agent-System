# Backend Dockerfile (Development)
# Hot-reload enabled with uvicorn --reload

FROM python:3.11-slim

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y \
    build-essential \
    curl \
    git \
    && rm -rf /var/lib/apt/lists/*

# Install uv for fast dependency management
RUN pip install --no-cache-dir uv

# Copy dependency file first for layer caching
COPY pyproject.toml README.md* ./
RUN touch README.md && uv pip install --system -e .

# Source code is mounted as volume — no COPY needed

# Non-root user
RUN useradd -m -u 1000 aos && \
    mkdir -p /home/aos/.claude/projects /app/data/summaries && \
    chown -R aos:aos /app /home/aos
USER aos

ENV PYTHONUNBUFFERED=1

EXPOSE 8000

HEALTHCHECK --interval=30s --timeout=10s --start-period=30s --retries=3 \
    CMD curl -f http://localhost:8000/health || exit 1

CMD ["uvicorn", "api.app:app", "--host", "0.0.0.0", "--port", "8000", "--reload", "--reload-dir", "/app"]
