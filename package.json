{
  "name": "Agent-System",
  "version": "0.1.0",
  "private": true,
  "description": "AOS Monitor placeholder",
  "scripts": {
    "test": "echo 'No tests configured yet'",
    "lint": "cd src/dashboard && npm run lint",
    "type-check": "cd src/dashboard && npx tsc --noEmit",
    "build": "cd src/dashboard && npm run build",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.0",
    "lint-staged": "^15.4.0"
  },
  "lint-staged": {
    "src/dashboard/**/*.{ts,tsx}": [
      "bash -c 'cd src/dashboard && npx tsc --noEmit'",
      "bash -c 'cd src/dashboard && npx eslint --max-warnings 0'"
    ],
    "src/backend/**/*.py": [
      "ruff check --select E,F"
    ]
  }
}
